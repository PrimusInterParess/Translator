# Copy this file to ".env" and fill your secrets.
#
# Notes:
# - For nested ASP.NET Core config keys, use "__" (double underscore), e.g. "Gemini__ApiKey".
# - `.env` files are ignored by git (see `.gitignore`).

# Google Cloud Text-to-Speech (proxy `/tts`)
Tts__Google__ApiKey=
PORT=8788

# LLM provider: Gemini (default) or Ollama (local)
Llm__Provider=Gemini

# Ollama (required when Llm__Provider=Ollama; defaults live in appsettings.json — override here)
# Prerequisites: install Ollama, run `ollama pull` for the model set in Ollama__Model
# Docker: use Ollama__BaseUrl=http://host.docker.internal:11434
Ollama__BaseUrl=http://127.0.0.1:11434
Ollama__Model=qwen2.5:7b
# Optional (Windows user env, then restart Ollama): keep model loaded between requests
# OLLAMA_KEEP_ALIVE=30m

# Gemini API (when Llm__Provider=Gemini)
Gemini__ApiKey=
Gemini__Model=gemini-2.5-flash-lite
Gemini__GenerateContentBaseUrl=https://generativelanguage.googleapis.com/v1/models

